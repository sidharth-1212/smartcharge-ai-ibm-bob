# IBM Bob Configuration
IBM_BOB_MODEL_ID=ibm/granite-13b-chat-v2

# Database Configuration (SQLite for demo)
DATABASE_URL=sqlite:///./smartcharge.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# Redis Configuration (disabled for demo)
REDIS_URL=
REDIS_CACHE_TTL=300
REDIS_ENABLED=False

# Application Settings
APP_NAME=SmartCharge AI
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO
ENVIRONMENT=development

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Telemetry Settings
TELEMETRY_INTERVAL_SECONDS=5
TELEMETRY_BATCH_SIZE=100

# Charging Modes
FAST_CHARGE_POWER_KW=11.0
ECO_MODE_POWER_KW=3.5
PAUSE_POWER_KW=0.0

# Decision Engine Settings
DECISION_CONFIDENCE_THRESHOLD=0.7
MAX_DECISION_RETRIES=3
DECISION_TIMEOUT_SECONDS=10

# WebSocket Settings
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=1000

# Monitoring & Logging
SENTRY_DSN=
DATADOG_API_KEY=
LOG_FILE_PATH=logs/smartcharge.log
LOG_ROTATION_SIZE_MB=100
LOG_RETENTION_DAYS=30